# ====================================================================
# GHOSTTY CONFIGURATION
# ====================================================================

# Theme
theme = catppuccin-mocha
minimum-contrast = 1.1

# Transparency
background-opacity = 0.96
background-blur = 12
# Alternative presets:
# background-opacity = 0.90, background-blur = 10  — ambient tint, more transparent
# background-opacity = 0.94, background-blur = 12  — subtle, original other-machine config
# background-opacity = 0.97, background-blur = 16  — barely perceptible, high blur

# Font
font-family = "Hack Nerd Font"
font-size = 14
font-thicken = true

# Window
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-padding-color = extend
scrollbar = system
window-decoration = true
macos-titlebar-style = tabs
window-save-state = always
tab-inherit-working-directory = true
split-inherit-working-directory = true
window-inherit-working-directory = true
confirm-close-surface = true

# Cursor
cursor-style = block
cursor-style-blink = false
cursor-click-to-move = true

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Copy/paste
copy-on-select = clipboard
clipboard-paste-protection = true
clipboard-trim-trailing-spaces = true
# clipboard-read: `ask` over `allow` — `allow` lets any terminal program silently
# read clipboard (password/token exfiltration risk). `ask` shows a confirmation
# dialog per OSC 52 read request. Needed by: tmux clipboard sync, neovim over SSH.
clipboard-read = ask

# Mouse
mouse-hide-while-typing = true

# Notifications
notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
notify-on-command-finish-after = 10s

# Quick terminal
quick-terminal-position = top
quick-terminal-size = 40%
quick-terminal-screen = main
quick-terminal-animation-duration = 0.2
quick-terminal-space-behavior = move
quick-terminal-autohide = true

# Keybindings (macOS friendly)
keybind = super+t=new_tab
keybind = super+w=close_surface
keybind = super+shift+left=previous_tab
keybind = super+shift+right=next_tab
keybind = super+1=goto_tab:1
keybind = super+2=goto_tab:2
keybind = super+3=goto_tab:3
keybind = super+4=goto_tab:4
keybind = super+5=goto_tab:5

keybind = global:ctrl+º=toggle_quick_terminal

# Quick reload config
keybind = super+shift+comma=reload_config

# Operational
auto-update = check
macos-auto-secure-input = true
# ~50 MB; memory allocated lazily as scrollback accumulates
scrollback-limit = 50000000
