{{ if eq .chezmoi.os "darwin" -}}
#!/bin/bash
# run_once_configure-macos-defaults.sh — applies macOS system preferences
# chezmoi executes this once on first apply (content-hash keyed).

set -o pipefail

info() {
    echo "[dotfiles] $*"
}

warn() {
    echo "[dotfiles] WARNING: $*" >&2
}

error() {
    echo "[dotfiles] ERROR: $*" >&2
}

confirm() {
    local prompt="$1"
    local reply
    if ! read -r -p "[dotfiles] $prompt [Y/n] " reply </dev/tty 2>/dev/null; then
        warn "No TTY available for '$prompt' — defaulting to no"
        return 1
    fi
    case "$reply" in
        [nN]*) return 1 ;;
        *) return 0 ;;
    esac
}

info "Configuring macOS system defaults..."

FINDER_ACCEPTED=false
DOCK_ACCEPTED=false

# ------------------------------------------------------------------
# Finder
# ------------------------------------------------------------------
info ""
info "  Finder settings:"
info "    • Show hidden files (dotfiles, .git become visible)"
info "    • Show path bar (full path at bottom of window)"
info "    • Show status bar (item count and free space)"
info "    • Auto-delete Trash after 30 days"
info "    • Sort folders first in file listings"
info "    • Disable extension change warning"
info "    • Open new windows in ~/Downloads"
info "    • Show all file extensions"
info "    • Unhide ~/Library folder"
if confirm "Apply Finder settings?"; then
    FINDER_ACCEPTED=true
    defaults write com.apple.finder AppleShowAllFiles -bool true
    defaults write com.apple.finder ShowPathbar -bool true
    defaults write com.apple.finder ShowStatusBar -bool true
    defaults write com.apple.finder FXRemoveOldTrashItems -bool true
    defaults write com.apple.finder _FXSortFoldersFirst -bool true
    defaults write com.apple.finder FXEnableExtensionChangeWarning -bool false
    defaults write com.apple.finder NewWindowTarget -string "PfLo"
    defaults write com.apple.finder NewWindowTargetPath -string "file://$HOME/Downloads/"
    defaults write NSGlobalDomain AppleShowAllExtensions -bool true
    chflags nohidden ~/Library
    info "  Finder settings applied."
else
    info "  Skipping Finder settings."
fi

# ------------------------------------------------------------------
# Dock
# ------------------------------------------------------------------
info ""
info "  Dock settings:"
info "    • Auto-hide the Dock"
info "    • Hide recent applications in Dock"
info "    • Set icon tile size to 62px"
if confirm "Apply Dock settings?"; then
    DOCK_ACCEPTED=true
    defaults write com.apple.dock autohide -bool true
    defaults write com.apple.dock show-recents -bool false
    defaults write com.apple.dock tilesize -int 62
    info "  Dock settings applied."
else
    info "  Skipping Dock settings."
fi

# ------------------------------------------------------------------
# Trackpad
# ------------------------------------------------------------------
info ""
info "  Trackpad settings:"
info "    • Enable tap to click"
if confirm "Apply Trackpad settings?"; then
    defaults write com.apple.AppleMultitouchTrackpad Clicking -bool true
    info "  Trackpad settings applied."
else
    info "  Skipping Trackpad settings."
fi

# ------------------------------------------------------------------
# Keyboard
# ------------------------------------------------------------------
info ""
info "  Keyboard settings:"
info "    • Disable auto-capitalize"
info "    • Disable smart dashes (-- instead of —)"
info "    • Disable smart quotes"
info "    • Disable auto-period (double space won't insert period)"
info "    • Fast key repeat (KeyRepeat=2, InitialKeyRepeat=15)"
if confirm "Apply Keyboard settings?"; then
    defaults write NSGlobalDomain NSAutomaticCapitalizationEnabled -bool false
    defaults write NSGlobalDomain NSAutomaticDashSubstitutionEnabled -bool false
    defaults write NSGlobalDomain NSAutomaticQuoteSubstitutionEnabled -bool false
    defaults write NSGlobalDomain NSAutomaticPeriodSubstitutionEnabled -bool false
    defaults write NSGlobalDomain KeyRepeat -int 2
    defaults write NSGlobalDomain InitialKeyRepeat -int 15
    info "  Keyboard settings applied."
else
    info "  Skipping Keyboard settings."
fi

# ------------------------------------------------------------------
# Hot corners (all disabled)
# ------------------------------------------------------------------
info ""
info "  Hot corners settings:"
info "    • Disable all four hot corners"
if confirm "Apply Hot corners settings?"; then
    defaults write com.apple.dock wvous-tl-corner -int 0
    defaults write com.apple.dock wvous-tr-corner -int 0
    defaults write com.apple.dock wvous-bl-corner -int 0
    defaults write com.apple.dock wvous-br-corner -int 0
    DOCK_ACCEPTED=true
    info "  Hot corners settings applied."
else
    info "  Skipping Hot corners settings."
fi

# ------------------------------------------------------------------
# Misc
# ------------------------------------------------------------------
info ""
info "  Misc settings:"
info "    • Disable Preview window restore on open"
info "    • Hide Siri from menu bar"
if confirm "Apply Misc settings?"; then
    defaults write com.apple.Preview ApplePersistenceIgnoreState -bool true
    defaults write com.apple.Siri StatusMenuVisible -bool false
    info "  Misc settings applied."
else
    info "  Skipping Misc settings."
fi

# ------------------------------------------------------------------
# Restart affected services (only if their group was accepted)
# ------------------------------------------------------------------
if $FINDER_ACCEPTED; then
    info "  Restarting Finder..."
    killall Finder 2>/dev/null || true
fi
if $DOCK_ACCEPTED; then
    info "  Restarting Dock..."
    killall Dock 2>/dev/null || true
fi

info "macOS defaults configured."
info "Note: some settings (KeyRepeat, InitialKeyRepeat) may require logout to take full effect."
{{ end -}}
