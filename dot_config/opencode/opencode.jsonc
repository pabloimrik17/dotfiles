{
    "$schema": "https://opencode.ai/config.json",
    "model": "anthropic/claude-opus-4-6",
    "tui": {
        "scroll_acceleration": {
            "enabled": true,
        },
    },
    // websearch-cited must be LAST to avoid impacting other plugins' auth
    "plugin": [
        "@tarquinen/opencode-dcp@latest",
        "@plannotator/opencode@latest",
        "opencode-wakatime",
        "opencode-websearch-cited@1.2.0",
    ],
    "mcp": {
        "expect": {
            "type": "local",
            "command": ["npx", "-y", "expect-cli@latest", "mcp"],
            "enabled": true,
        },
    },
    "formatter": {
        "oxfmt": {
            "command": ["oxfmt", "$FILE"],
        },
    },
    "permission": {
        // File modifications — default is allow, we want confirmation
        "edit": "ask",

        // External access — default is allow, we want confirmation
        "webfetch": "ask",

        // Shell commands — default is allow, granular override
        "bash": {
            "*": "ask",

            // --- DENY: dangerous operations ---
            "sudo *": "deny",
            "curl * | bash": "deny",
            "curl * | sh": "deny",
            "wget * | bash": "deny",
            "wget * | sh": "deny",
            "git push --force *": "deny",
            "git push * --force": "deny",
            "git push -f *": "deny",
            "git push * -f": "deny",
            "npm publish *": "deny",
            "bun publish *": "deny",
            "chmod -R 777 *": "deny",

            // --- ALLOW: filesystem read-only ---
            "ls": "allow",
            "ls *": "allow",
            "cat *": "allow",
            "head *": "allow",
            "tail *": "allow",
            "wc *": "allow",
            "pwd": "allow",
            "echo *": "allow",
            "which *": "allow",
            "file *": "allow",
            "find *": "allow",
            "rg *": "allow",
            "du *": "allow",
            "tree *": "allow",
            "stat *": "allow",

            // --- ALLOW: git read-only ---
            "git status": "allow",
            "git status *": "allow",
            "git diff": "allow",
            "git diff *": "allow",
            "git log": "allow",
            "git log *": "allow",
            "git show *": "allow",
            "git branch": "allow",
            "git branch *": "allow",
            "git remote *": "allow",
            "git stash list *": "allow",
            "git ls-tree *": "allow",
            "git rev-parse *": "allow",
            "git config --get *": "allow",

            // --- ALLOW: git write ---
            "git add *": "allow",
            "git fetch *": "allow",
            "git push *": "allow",

            // --- ALLOW: build/test ---
            "bun run *": "allow",
            "bun test *": "allow",
            "bun install --frozen-lockfile": "allow",
            "pnpm run *": "allow",
            "pnpm test *": "allow",
            "pnpm install --frozen-lockfile": "allow",

            // --- ALLOW: version checks ---
            "node --version": "allow",
            "bun --version": "allow",
            "npm --version": "allow",

            // --- ALLOW: chezmoi read ---
            "chezmoi cat *": "allow",
            "chezmoi diff *": "allow",
            "chezmoi managed *": "allow",
            "chezmoi source-path *": "allow",
            "chezmoi status *": "allow",
            "chezmoi data *": "allow",

            // --- ALLOW: package manager info ---
            "brew info *": "allow",
            "brew list *": "allow",
            "brew outdated *": "allow",
            "npm info *": "allow",

            // --- ALLOW: openspec ---
            "openspec list *": "allow",
            "openspec status *": "allow",
            "openspec instructions *": "allow",
            "bunx openspec *": "allow",

            // --- ALLOW: worktrunk ---
            "wt list *": "allow",
            "wt config *": "allow",
            "wt --help *": "allow",

            // --- ALLOW: github cli ---
            "gh api *": "allow",
            "gh issue *": "allow",
            "gh pr *": "allow",
            "gh repo *": "allow",

            // --- ALLOW: claude code cli ---
            "claude mcp *": "allow",
            "claude plugin *": "allow",
            "claude skill *": "allow",
            "claude skills *": "allow",
        },

        // Prevent infinite tool loops — default is ask, we want hard deny
        "doom_loop": "deny",
    },
}
