    "superpowers-lab@superpowers-marketplace"
    "claude-code-wakatime@wakatime"
    "plannotator@plannotator"
    "worktrunk@worktrunk"
    "beads@beads-marketplace"
    "code-simplifier@claude-plugins-official"
)

if command -v claude &>/dev/null; then
    # Pre-scan marketplaces and plugins
    CC_MARKETPLACE_JSON="$(claude plugin marketplace list --json 2>/dev/null || true)"
    CC_PLUGIN_JSON="$(claude plugin list --json 2>/dev/null || true)"

    marketplace_installed() {
        local repo="$1"
        if [ -n "$CC_MARKETPLACE_JSON" ]; then
            echo "$CC_MARKETPLACE_JSON" | grep -q "$repo"
        else
            return 1
        fi
    }

    plugin_installed() {
        local plugin_id="$1"
        if [ -n "$CC_PLUGIN_JSON" ]; then
            echo "$CC_PLUGIN_JSON" | grep -q "$plugin_id"
        else
            return 1
        fi
    }

    # Check if plannotator CLI is pending
    PLANNOTATOR_PENDING=0
    command -v plannotator &>/dev/null || PLANNOTATOR_PENDING=1

    # Count pending marketplaces
    PENDING_MP=0
    TOTAL_MP=${#CC_MARKETPLACES[@]}
    for repo in "${CC_MARKETPLACES[@]}"; do
        if ! marketplace_installed "$repo"; then
            PENDING_MP=$((PENDING_MP + 1))
        fi
    done

    # Count pending plugins
    PENDING_PL=0
    TOTAL_PL=${#CC_PLUGINS[@]}
    for plugin in "${CC_PLUGINS[@]}"; do
        if ! plugin_installed "$plugin"; then
            PENDING_PL=$((PENDING_PL + 1))
        fi
    done

    if [ "$PLANNOTATOR_PENDING" -eq 0 ] && [ "$PENDING_MP" -eq 0 ] && [ "$PENDING_PL" -eq 0 ]; then
        info "CC marketplaces: $TOTAL_MP/$TOTAL_MP registered"
        info "CC plugins: $TOTAL_PL/$TOTAL_PL installed"
    else
        if confirm "Install Claude Code plugin dependencies ($PLANNOTATOR_PENDING cli + $PENDING_MP marketplaces + $PENDING_PL plugins pending)?"; then
            if command -v plannotator &>/dev/null; then
                info "  plannotator — already installed, skipping"
            else
                info "  Installing plannotator..."
                if ! curl -fsSL https://plannotator.ai/install.sh | bash; then
                    error "Failed to install plannotator"
                fi
                # plannotator installs to ~/.local/bin which may not be in PATH yet
                export PATH="$HOME/.local/bin:$PATH"
                if ! command -v plannotator &>/dev/null; then
                    error "plannotator installed but not found in PATH"
                fi
            fi

            info "  Registering Claude Code plugin marketplaces..."
            for repo in "${CC_MARKETPLACES[@]}"; do
                if marketplace_installed "$repo"; then
                    info "  $repo — already registered, skipping"
                else
                    run_claude_step "marketplace $repo" claude plugin marketplace add "$repo"
                fi
            done

            info "  Installing Claude Code plugins..."
            for plugin in "${CC_PLUGINS[@]}"; do
                if plugin_installed "$plugin"; then
                    info "  $plugin — already installed, skipping"
                else
                    run_claude_step "plugin $plugin" claude plugin install "$plugin"
                fi
            done
        else
            info "Skipping Claude Code plugin dependencies."
        fi
    fi
else
    warn "Claude Code is not installed — skipping plugin setup"
fi

# ------------------------------------------------------------------
# Group 9: Agent skills (skills.sh)
# ------------------------------------------------------------------
if confirm "Install global agent skills via skills.sh?"; then
    if command -v npx &>/dev/null; then
        # Query already-installed global skills
        INSTALLED_SKILLS=""
        if SKILLS_JSON="$(npx -y skills list -g --json 2>/dev/null)"; then
            INSTALLED_SKILLS="$SKILLS_JSON"
        else
            warn "Could not query installed global skills; proceeding without skip checks"
        fi

        skill_installed() {
            local name="$1"
            if [ -n "$INSTALLED_SKILLS" ]; then
                echo "$INSTALLED_SKILLS" | grep -q "\"name\": \"$name\""
            else
                return 1
            fi
        }

        install_skill() {
            local repo="$1"
            local name="$2"
            if skill_installed "$name"; then
                info "  $name — already installed, skipping"
            else
                run_claude_step "skill $name" npx -y skills add "$repo" --skill "$name" -g -y
            fi
        }

        install_skill "vercel-labs/skills" "find-skills"
        install_skill "vercel-labs/agent-skills" "vercel-react-best-practices"
        install_skill "vercel-labs/agent-skills" "web-design-guidelines"
        install_skill "vercel-labs/agent-skills" "vercel-composition-patterns"
        install_skill "anthropics/skills" "frontend-design"
        install_skill "anthropics/skills" "skill-creator"
        install_skill "anthropics/skills" "pdf"
        install_skill "anthropics/skills" "pptx"
        install_skill "anthropics/skills" "docx"
        install_skill "anthropics/skills" "xlsx"
        install_skill "coderabbitai/skills" "code-review"
        install_skill "coderabbitai/skills" "autofix"
    else
        warn "npx is not available — skipping agent skills installation"
    fi
else
    info "Skipping agent skills."
fi
# ------------------------------------------------------------------
# Manual install instructions (always printed)
# ------------------------------------------------------------------
info ""
info "=== Manual Installation Required ==="
info ""
info "The following apps require manual installation:"
info "  - Last.fm Scrobbler: https://last.fm/about/trackmymusic"
info "  - CleanMyMac: requires license — install from https://cleanmymac.com"
info "  - Adobe Creative Cloud: requires Adobe login — install from https://creativecloud.adobe.com"
info "  - 1Password for Safari: install from the Mac App Store (Safari extension)"
info "  - CodeRabbit: coderabbit auth login (opens browser for authentication)"
info ""

{{ else -}}
# ====================================================================
# Non-macOS — print manual instructions
# ====================================================================

info "This system is not macOS. Automatic installation is not supported."
info ""
info "Please install the following packages manually:"
info ""
info "  CLI tools: git, git-delta, starship, eza, bat, zoxide, atuin, fzf, ripgrep, lazygit, worktrunk, terminal-notifier, fd, direnv, beads, gh, tmux, uv, wget, opencode"
info "    - fd: on Debian/Ubuntu install fd-find; binary is fdfind — symlink with: ln -s \$(command -v fdfind) ~/.local/bin/fd"
info "    - worktrunk: brew install worktrunk  OR  cargo install worktrunk"
info "  Fonts: Hack Nerd Font + JetBrainsMono Nerd Font (https://www.nerdfonts.com/)"
info "  Shell: oh-my-zsh (https://ohmyz.sh/)"
info "  Zsh plugins:"
info "    - you-should-use: git clone https://github.com/MichaelAquilina/zsh-you-should-use.git \${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/you-should-use"
info "    - zsh-autosuggestions (via package manager or git clone)"
info "    - zsh-syntax-highlighting (via package manager or git clone)"
info "    - zsh-completions: apt install zsh-completions"
info "      Or: sudo git clone https://github.com/zsh-users/zsh-completions.git /usr/share/zsh-completions"
info "  gh extensions: gh extension install dlvhdr/gh-dash"
info "  Bat theme: Catppuccin Mocha"
info "    mkdir -p \"\$(bat --config-dir)/themes\""
info "    curl -fsSLo \"\$(bat --config-dir)/themes/Catppuccin Mocha.tmTheme\" https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme"
info "    bat cache --build"
info "  Claude Code plugins:"
info "    - plannotator: curl -fsSL https://plannotator.ai/install.sh | bash"
info "    - claude plugin marketplace add backnotprop/plannotator && claude plugin install plannotator@plannotator"
info "    - claude plugin marketplace add max-sixty/worktrunk && claude plugin install worktrunk@worktrunk"
info "  Agent skills (requires npx/Node.js):"
info "    npx -y skills add vercel-labs/skills --skill find-skills -g -y"
info "    npx -y skills add vercel-labs/agent-skills --skill vercel-react-best-practices -g -y"
info "    npx -y skills add vercel-labs/agent-skills --skill web-design-guidelines -g -y"
info "    npx -y skills add vercel-labs/agent-skills --skill vercel-composition-patterns -g -y"
info "    npx -y skills add anthropics/skills --skill frontend-design -g -y"
info "    npx -y skills add anthropics/skills --skill skill-creator -g -y"
info "    npx -y skills add anthropics/skills --skill pdf -g -y"
info "    npx -y skills add anthropics/skills --skill pptx -g -y"
info "    npx -y skills add anthropics/skills --skill docx -g -y"
info "    npx -y skills add anthropics/skills --skill xlsx -g -y"
info ""

{{ end -}}

if [ "$ERRORS" -gt 0 ]; then
    warn "$ERRORS error(s) occurred during installation. Some packages may not be available."
    exit 1
fi

info "Installation complete!"
