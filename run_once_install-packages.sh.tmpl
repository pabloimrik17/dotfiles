#!/bin/bash
# run_once_install-packages.sh — chezmoi runs this once on first apply
# Installs tool dependencies with interactive confirmation per group.

# Note: set -e intentionally omitted — script continues on individual package failures
set -o pipefail

ERRORS=0

info() {
    echo "[dotfiles] $*"
}

warn() {
    echo "[dotfiles] WARNING: $*" >&2
}

error() {
    echo "[dotfiles] ERROR: $*" >&2
    ERRORS=$((ERRORS + 1))
}

run_claude_step() {
    local label="$1"
    shift
    if ! "$@" 2>&1; then
        error "Claude step failed: $label ($*)"
        return 0  # continue script
    fi
}

confirm() {
    local prompt="$1"
    local reply
    read -r -p "[dotfiles] $prompt [Y/n] " reply </dev/tty
    case "$reply" in
        [nN]*) return 1 ;;
        *) return 0 ;;
    esac
}

{{ if eq .chezmoi.os "darwin" -}}
# ====================================================================
# macOS — install via Homebrew
# ====================================================================

if ! command -v brew &>/dev/null; then
    error "Homebrew is not installed. Please install it first: https://brew.sh"
    exit 1
fi

# ------------------------------------------------------------------
# Group 1: Brew packages
# ------------------------------------------------------------------
BREW_PACKAGES=(git git-delta starship eza bat zoxide atuin fzf ripgrep lazygit worktrunk)

# Resolve the binary name for a given package (bash 3 compatible)
pkg_bin() {
    case "$1" in
        git-delta) echo "delta" ;;
        ripgrep)   echo "rg" ;;
        worktrunk) echo "wt" ;;
        *)         echo "$1" ;;
    esac
}

if confirm "Install brew packages (${BREW_PACKAGES[*]})?"; then
    info "Installing brew packages..."
    for pkg in "${BREW_PACKAGES[@]}"; do
        bin="$(pkg_bin "$pkg")"
        if command -v "$bin" &>/dev/null; then
            info "  $pkg — already installed, skipping"
        else
            info "  Installing $pkg..."
            if ! brew install "$pkg"; then
                error "Failed to install $pkg"
            fi
        fi
    done
else
    info "Skipping brew packages."
fi

# ------------------------------------------------------------------
# Bat theme: Catppuccin Mocha
# ------------------------------------------------------------------
if command -v bat &>/dev/null; then
    BAT_THEMES_DIR="$(bat --config-dir)/themes"
    if [ -f "$BAT_THEMES_DIR/Catppuccin Mocha.tmTheme" ]; then
        info "  bat Catppuccin Mocha theme — already installed, skipping"
    else
        info "  Installing bat Catppuccin Mocha theme..."
        mkdir -p "$BAT_THEMES_DIR"
        if curl -fsSLo "$BAT_THEMES_DIR/Catppuccin Mocha.tmTheme" \
            "https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme"; then
            bat cache --build
            info "  bat Catppuccin Mocha theme installed successfully"
        else
            error "Failed to download bat Catppuccin Mocha theme"
        fi
    fi
fi

# ------------------------------------------------------------------
# Group 2: Fonts
# ------------------------------------------------------------------
if confirm "Install Hack Nerd Font?"; then
    info "Installing Hack Nerd Font..."
    if brew list --cask font-hack-nerd-font &>/dev/null; then
        info "  font-hack-nerd-font — already installed (via brew), skipping"
    elif ls ~/Library/Fonts/HackNerdFont*.ttf &>/dev/null 2>&1; then
        info "  font-hack-nerd-font — already installed (manual), skipping"
    else
        if ! brew install --cask font-hack-nerd-font; then
            error "Failed to install font-hack-nerd-font"
        fi
    fi
else
    info "Skipping font installation."
fi

# ------------------------------------------------------------------
# Group 3: Oh-my-zsh + plugins
# ------------------------------------------------------------------
if confirm "Install oh-my-zsh and zsh plugins?"; then
    # oh-my-zsh
    if [ -d "$HOME/.oh-my-zsh" ]; then
        info "  oh-my-zsh — already installed, skipping"
    else
        info "  Installing oh-my-zsh..."
        if ! sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended; then
            error "Failed to install oh-my-zsh"
        fi
    fi

    # you-should-use plugin (git clone)
    YSU_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/you-should-use"
    if [ -d "$YSU_DIR" ]; then
        info "  you-should-use plugin — already installed, skipping"
    else
        info "  Cloning you-should-use plugin..."
        if ! git clone https://github.com/MichaelAquilina/you-should-use.git "$YSU_DIR"; then
            error "Failed to clone you-should-use plugin"
        fi
    fi

    # zsh-autosuggestions and zsh-syntax-highlighting via brew
    for pkg in zsh-autosuggestions zsh-syntax-highlighting zsh-completions; do
        if brew list "$pkg" &>/dev/null; then
            info "  $pkg — already installed, skipping"
        else
            info "  Installing $pkg..."
            if ! brew install "$pkg"; then
                error "Failed to install $pkg"
            fi
        fi
    done
else
    info "Skipping oh-my-zsh and zsh plugins."
fi

# ------------------------------------------------------------------
# Group 4: OpenCode plugins
# ------------------------------------------------------------------
if confirm "Install OpenCode plugin dependencies (plannotator, superpowers)?"; then
    if command -v opencode &>/dev/null; then
        if command -v plannotator &>/dev/null; then
            info "  plannotator — already installed, skipping"
        else
            info "  Installing plannotator..."
            if ! curl -fsSL https://plannotator.ai/install.sh | bash; then
                error "Failed to install plannotator"
            fi
            if ! command -v plannotator &>/dev/null; then
                error "plannotator installed but not found in PATH"
            fi
        fi

        info "  Installing superpowers..."
        SUPERPOWERS_DIR="$HOME/.config/opencode/superpowers"
        if [ -d "$SUPERPOWERS_DIR" ]; then
            info "  superpowers — already installed, skipping"
        else
            if git clone https://github.com/obra/superpowers.git "$SUPERPOWERS_DIR"; then
                mkdir -p "$HOME/.config/opencode/plugins"
                ln -sf "$SUPERPOWERS_DIR/.opencode/plugins/superpowers.js" "$HOME/.config/opencode/plugins/superpowers.js"
                mkdir -p "$HOME/.config/opencode/skills"
                ln -sf "$SUPERPOWERS_DIR/skills" "$HOME/.config/opencode/skills/superpowers"
            else
                error "Failed to clone superpowers"
            fi
        fi
    else
        warn "OpenCode is not installed — skipping plugin setup"
    fi
else
    info "Skipping OpenCode plugin dependencies."
fi

# ------------------------------------------------------------------
# Group 5: Claude Code plugin dependencies
# ------------------------------------------------------------------
if confirm "Install Claude Code plugin dependencies (plannotator, worktrunk plugin)?"; then
    if command -v claude &>/dev/null; then
        if command -v plannotator &>/dev/null; then
            info "  plannotator — already installed, skipping"
        else
            info "  Installing plannotator..."
            if ! curl -fsSL https://plannotator.ai/install.sh | bash; then
                error "Failed to install plannotator"
            fi
            if ! command -v plannotator &>/dev/null; then
                error "plannotator installed but not found in PATH"
            fi
        fi

        info "  Registering Claude Code plugin marketplaces..."
        run_claude_step "marketplace anthropics/claude-plugins-official" claude plugin marketplace add anthropics/claude-plugins-official
        run_claude_step "marketplace jarrodwatts/claude-hud" claude plugin marketplace add jarrodwatts/claude-hud
        run_claude_step "marketplace expo/skills" claude plugin marketplace add expo/skills
        run_claude_step "marketplace pabloimrik17/monolab" claude plugin marketplace add pabloimrik17/monolab
        run_claude_step "marketplace obra/superpowers-marketplace" claude plugin marketplace add obra/superpowers-marketplace
        run_claude_step "marketplace wakatime" claude plugin marketplace add https://github.com/wakatime/claude-code-wakatime.git
        run_claude_step "marketplace nrwl/nx-ai-agents-config" claude plugin marketplace add nrwl/nx-ai-agents-config
        run_claude_step "marketplace backnotprop/plannotator" claude plugin marketplace add backnotprop/plannotator
        run_claude_step "marketplace max-sixty/worktrunk" claude plugin marketplace add max-sixty/worktrunk

        info "  Installing Claude Code plugins..."
        run_claude_step "plugin typescript-lsp" claude plugin install typescript-lsp@claude-plugins-official
        run_claude_step "plugin frontend-design" claude plugin install frontend-design@claude-plugins-official
        run_claude_step "plugin code-review" claude plugin install code-review@claude-plugins-official
        run_claude_step "plugin commit-commands" claude plugin install commit-commands@claude-plugins-official
        run_claude_step "plugin claude-md-management" claude plugin install claude-md-management@claude-plugins-official
        run_claude_step "plugin plugin-dev" claude plugin install plugin-dev@claude-plugins-official
        run_claude_step "plugin skill-creator" claude plugin install skill-creator@claude-plugins-official
        run_claude_step "plugin claude-hud" claude plugin install claude-hud@claude-hud
        run_claude_step "plugin expo-app-design" claude plugin install expo-app-design@expo-plugins
        run_claude_step "plugin upgrading-expo" claude plugin install upgrading-expo@expo-plugins
        run_claude_step "plugin expo-deployment" claude plugin install expo-deployment@expo-plugins
        run_claude_step "plugin expo-developer" claude plugin install expo-developer@monolab
        run_claude_step "plugin experiments" claude plugin install experiments@monolab
        run_claude_step "plugin double-shot-latte" claude plugin install double-shot-latte@superpowers-marketplace
        run_claude_step "plugin elements-of-style" claude plugin install elements-of-style@superpowers-marketplace
        run_claude_step "plugin episodic-memory" claude plugin install episodic-memory@superpowers-marketplace
        run_claude_step "plugin superpowers" claude plugin install superpowers@superpowers-marketplace
        run_claude_step "plugin superpowers-chrome" claude plugin install superpowers-chrome@superpowers-marketplace
        run_claude_step "plugin superpowers-developing-for-claude-code" claude plugin install superpowers-developing-for-claude-code@superpowers-marketplace
        run_claude_step "plugin superpowers-lab" claude plugin install superpowers-lab@superpowers-marketplace
        run_claude_step "plugin claude-code-wakatime" claude plugin install claude-code-wakatime@wakatime
        run_claude_step "plugin plannotator" claude plugin install plannotator@plannotator
        run_claude_step "plugin worktrunk" claude plugin install worktrunk@worktrunk
    else
        warn "Claude Code is not installed — skipping plugin setup"
    fi
else
    info "Skipping Claude Code plugin dependencies."
fi
{{ else -}}
# ====================================================================
# Non-macOS — print manual instructions
# ====================================================================

info "This system is not macOS. Automatic installation is not supported."
info ""
info "Please install the following packages manually:"
info ""
info "  CLI tools: git, starship, eza, bat, zoxide, atuin, fzf, ripgrep, lazygit, worktrunk"
info "    - worktrunk: brew install worktrunk  OR  cargo install worktrunk"
info "  Font: Hack Nerd Font (https://www.nerdfonts.com/)"
info "  Shell: oh-my-zsh (https://ohmyz.sh/)"
info "  Zsh plugins:"
info "    - you-should-use: git clone https://github.com/MichaelAquilina/you-should-use.git \${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/you-should-use"
info "    - zsh-autosuggestions (via package manager or git clone)"
info "    - zsh-syntax-highlighting (via package manager or git clone)"
info "    - zsh-completions: apt install zsh-completions"
info "      Or: sudo git clone https://github.com/zsh-users/zsh-completions.git /usr/share/zsh-completions"
info "  Bat theme: Catppuccin Mocha"
info "    mkdir -p \"\$(bat --config-dir)/themes\""
info "    curl -fsSLo \"\$(bat --config-dir)/themes/Catppuccin Mocha.tmTheme\" https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme"
info "    bat cache --build"
info "  Claude Code plugins:"
info "    - plannotator: curl -fsSL https://plannotator.ai/install.sh | bash"
info "    - claude plugin marketplace add backnotprop/plannotator && claude plugin install plannotator@plannotator"
info "    - claude plugin marketplace add max-sixty/worktrunk && claude plugin install worktrunk@worktrunk"
info ""

{{ end -}}

if [ "$ERRORS" -gt 0 ]; then
    warn "$ERRORS error(s) occurred during installation. Some packages may not be available."
    exit 1
fi

info "Installation complete!"
