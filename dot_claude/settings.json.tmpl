{
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "enabledPlugins": {
    "beads@beads-marketplace": true,
    "claude-code-setup@claude-plugins-official": true,
    "claude-code-wakatime@wakatime": true,
    "claude-hud@claude-hud": true,
    "claude-md-management@claude-plugins-official": true,
    "claude-session-driver@superpowers-marketplace": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "commander@monolab": true,
    "commit-commands@claude-plugins-official": true,
    "double-shot-latte@superpowers-marketplace": true,
    "elements-of-style@superpowers-marketplace": true,
    "episodic-memory@superpowers-marketplace": true,
    "experiments@monolab": true,
    "expo-developer@monolab": true,
    "expo@expo-plugins": true,
    "frontend-design@claude-plugins-official": true,
    "plannotator@plannotator": true,
    "plugin-dev@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers-chrome@superpowers-marketplace": true,
    "superpowers-developing-for-claude-code@superpowers-marketplace": true,
    "superpowers-lab@superpowers-marketplace": true,
    "superpowers@superpowers-marketplace": true,
{{- if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
    "superwhisper@superwhisper": true,
{{- end }}
    "typescript-lsp@claude-plugins-official": true,
    "worktrunk@worktrunk": true
  },
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "autoUpdate": true,
      "source": {
        "repo": "steveyegge/beads",
        "source": "github"
      }
    },
    "claude-hud": {
      "autoUpdate": true,
      "source": {
        "repo": "jarrodwatts/claude-hud",
        "source": "github"
      }
    },
    "claude-plugins-official": {
      "autoUpdate": true,
      "source": {
        "repo": "anthropics/claude-plugins-official",
        "source": "github"
      }
    },
    "expo-plugins": {
      "autoUpdate": true,
      "source": {
        "repo": "expo/skills",
        "source": "github"
      }
    },
    "monolab": {
      "autoUpdate": true,
      "source": {
        "repo": "pabloimrik17/monolab",
        "source": "github"
      }
    },
    "nx-claude-plugins": {
      "autoUpdate": true,
      "source": {
        "repo": "nrwl/nx-ai-agents-config",
        "source": "github"
      }
    },
    "plannotator": {
      "autoUpdate": true,
      "source": {
        "repo": "backnotprop/plannotator",
        "source": "github"
      }
    },
    "superpowers-marketplace": {
      "autoUpdate": true,
      "source": {
        "repo": "obra/superpowers-marketplace",
        "source": "github"
      }
    },
{{- if and (eq .chezmoi.os "darwin") (eq .chezmoi.arch "arm64") }}
    "superwhisper": {
      "autoUpdate": true,
      "source": {
        "repo": "superultrainc/superwhisper-claude-code",
        "source": "github"
      }
    },
{{- end }}
    "wakatime": {
      "autoUpdate": true,
      "source": {
        "source": "git",
        "url": "https://github.com/wakatime/claude-code-wakatime.git"
      }
    },
    "worktrunk": {
      "autoUpdate": true,
      "source": {
        "repo": "max-sixty/worktrunk",
        "source": "github"
      }
    }
  },
  "hooks": {
    "ElicitationResult": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf running > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf waiting > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|elicitation_dialog"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf running > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bd prime",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf idle > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "sh -c '[ -n \"$AOE_INSTANCE_ID\" ] || exit 0; mkdir -p /tmp/aoe-hooks/$AOE_INSTANCE_ID 2>/dev/null; printf running > /tmp/aoe-hooks/$AOE_INSTANCE_ID/status 2>/dev/null; exit 0'",
            "type": "command"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git fetch *)",
      "Bash(git push *)",
      "Bash(bun run typecheck)",
      "Bash(bun run lint)",
      "Bash(bun run build)",
      "Bash(bun run test)",
      "Bash(bun test *)",
      "Bash(bun install --frozen-lockfile)",
      "Bash(pnpm run typecheck)",
      "Bash(pnpm run lint)",
      "Bash(pnpm run build)",
      "Bash(pnpm run test)",
      "Bash(pnpm test *)",
      "Bash(pnpm install --frozen-lockfile)",
      "Bash(bun --version)",
      "Bash(npm --version)",
      "Bash(chezmoi cat *)",
      "Bash(chezmoi diff *)",
      "Bash(chezmoi managed *)",
      "Bash(chezmoi source-path *)",
      "Bash(chezmoi status *)",
      "Bash(chezmoi data *)",
      "Bash(chezmoi execute-template *)",
      "Bash(brew info *)",
      "Bash(brew list *)",
      "Bash(brew outdated *)",
      "Bash(npm info *)",
      "Bash(openspec list *)",
      "Bash(openspec status *)",
      "Bash(openspec instructions *)",
      "Bash(openspec validate *)",
      "Bash(openspec verify *)",
      "Bash(bunx openspec *)",
      "Bash(wt list *)",
      "Bash(wt config *)",
      "Bash(wt --help)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh repo *)",
      "Bash(gh search *)",
      "Bash(claude mcp *)",
      "Bash(claude plugin *)",
      "Bash(claude skill *)",
      "Bash(claude skills *)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:docs.anthropic.com)",
      "WebFetch(domain:api.anthropic.com)",
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:registry.modelcontextprotocol.io)",
      "WebFetch(domain:skills.sh)",
      "WebFetch(domain:deepwiki.com)",
      "WebFetch(domain:opencode.ai)",
      "mcp__context7__resolve-library-id",
      "mcp__context7__query-docs",
      "mcp__plugin_episodic-memory_episodic-memory__search",
      "mcp__plugin_episodic-memory_episodic-memory__read",
      "mcp__knip__knip-run",
      "mcp__knip__knip-docs",
      "mcp__eslint__lint-files",
      "mcp__memory__read_graph",
      "mcp__memory__search_nodes",
      "mcp__memory__open_nodes",
      "mcp__gh_grep__searchGitHub"
    ],
    "defaultMode": "auto",
    "deny": [
      "Bash(sudo *)",
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(git push --force *)",
      "Bash(git push * --force)",
      "Bash(git push -f *)",
      "Bash(git push * -f)",
      "Bash(npm publish *)",
      "Bash(bun publish *)",
      "Bash(chmod -R 777 *)"
    ]
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash -c 'export COLUMNS=200; plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"{{ .chezmoi.homeDir }}/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'",
    "type": "command"
  },
  "voiceEnabled": true
}