#!/bin/bash
# run_onchange_install-packages.sh — chezmoi re-runs this when its content changes
# Installs tool dependencies with interactive confirmation per group.

# Note: set -e intentionally omitted — script continues on individual package failures
set -o pipefail

# Redirect all output to the terminal so the user sees prompts and progress.
# chezmoi captures stdout/stderr of scripts by default, hiding interactive output.
exec > /dev/tty 2>&1

ERRORS=0

info() {
    echo "[dotfiles] $*"
}

warn() {
    echo "[dotfiles] WARNING: $*" >&2
}

error() {
    echo "[dotfiles] ERROR: $*" >&2
    ERRORS=$((ERRORS + 1))
}

run_claude_step() {
    local label="$1"
    shift
    # Claude Code runs on Bun, which crashes with EINVAL kqueue errors
    # when tty.WriteStream gets a non-TTY fd (oven-sh/bun#24158).
    # Wrap with `script` to provide a pseudo-TTY on macOS.
    local output_file
    output_file="$(mktemp)"
    if [[ "$OSTYPE" == darwin* ]]; then
        script -q "$output_file" "$@" >/dev/null 2>&1
    else
        "$@" >"$output_file" 2>&1
    fi
    local rc=$?
    if [ "$rc" -ne 0 ]; then
        error "Claude step failed: $label ($*)"
        # Show output on failure, filtering Bun runtime noise
        if [ -s "$output_file" ] && ! grep -q 'process\.std.*\.fd\|process\.std.*\.isTTY\|EINVAL.*kqueue' "$output_file"; then
            sed 's/^/        /' "$output_file" >&2
        fi
    fi
    rm -f "$output_file"
    return 0  # always continue script
}

confirm() {
    local prompt="$1"
    local reply
    printf "[dotfiles] %s [Y/n] " "$prompt"
    if ! read -r reply </dev/tty 2>/dev/null; then
        warn "No TTY available for '$prompt' — defaulting to no"
        return 1
    fi
    case "$reply" in
        [nN]*) return 1 ;;
        *) return 0 ;;
    esac
}

{{ if eq .chezmoi.os "darwin" -}}
# ====================================================================
# macOS — install via Homebrew
# ====================================================================

if ! command -v brew &>/dev/null; then
    error "Homebrew is not installed. Please install it first: https://brew.sh"
    exit 1
fi

# ------------------------------------------------------------------
# Group 1: Brew packages
# ------------------------------------------------------------------
BREW_PACKAGES=(git git-delta starship eza bat zoxide atuin fzf ripgrep lazygit worktrunk terminal-notifier fd direnv beads gh tmux uv mas wget opencode)

# Resolve the binary name for a given package (bash 3 compatible)
pkg_bin() {
    case "$1" in
        git-delta) echo "delta" ;;
        ripgrep)   echo "rg" ;;
        worktrunk) echo "wt" ;;
        beads)     echo "bd" ;;
        *)         echo "$1" ;;
    esac
}

# Pre-scan: check which brew packages are already installed
BREW_PENDING=0
for pkg in "${BREW_PACKAGES[@]}"; do
    if [ "$pkg" = "git" ]; then
        brew list git &>/dev/null || BREW_PENDING=$((BREW_PENDING + 1))
    else
        bin="$(pkg_bin "$pkg")"
        command -v "$bin" &>/dev/null || BREW_PENDING=$((BREW_PENDING + 1))
    fi
done

if [ "$BREW_PENDING" -eq 0 ]; then
    info "Brew packages: ${#BREW_PACKAGES[@]}/${#BREW_PACKAGES[@]} installed"
elif confirm "Install brew packages ($BREW_PENDING/${#BREW_PACKAGES[@]} pending)?"; then
    info "Installing brew packages..."
    for pkg in "${BREW_PACKAGES[@]}"; do
        if [ "$pkg" = "git" ]; then
            # Always install brew git — system git at /usr/bin/git is outdated
            if brew list git &>/dev/null; then
                info "  git — already installed (brew), skipping"
            else
                info "  Installing git (brew version)..."
                if ! brew install git; then
                    error "Failed to install git"
                fi
            fi
        else
            bin="$(pkg_bin "$pkg")"
            if command -v "$bin" &>/dev/null; then
                info "  $pkg — already installed, skipping"
            else
                info "  Installing $pkg..."
                if ! brew install "$pkg"; then
                    error "Failed to install $pkg"
                fi
            fi
        fi
    done
else
    info "Skipping brew packages."
fi

# ------------------------------------------------------------------
# Atuin: import existing shell history
# ------------------------------------------------------------------
if command -v atuin &>/dev/null; then
    ATUIN_COUNT="$(atuin history list 2>/dev/null | wc -l | tr -d ' ')"
    if [ "$ATUIN_COUNT" -eq 0 ]; then
        info "  Importing shell history into atuin..."
        atuin import auto 2>/dev/null || true
    fi
fi

# ------------------------------------------------------------------
# Bat theme: Catppuccin Mocha
# ------------------------------------------------------------------
if command -v bat &>/dev/null; then
    BAT_THEMES_DIR="$(bat --config-dir)/themes"
    if [ -f "$BAT_THEMES_DIR/Catppuccin Mocha.tmTheme" ]; then
        info "  bat Catppuccin Mocha theme — already installed, skipping"
    else
        info "  Installing bat Catppuccin Mocha theme..."
        mkdir -p "$BAT_THEMES_DIR"
        if curl -fsSLo "$BAT_THEMES_DIR/Catppuccin Mocha.tmTheme" \
            "https://raw.githubusercontent.com/catppuccin/bat/main/themes/Catppuccin%20Mocha.tmTheme"; then
            bat cache --build
            info "  bat Catppuccin Mocha theme installed successfully"
        else
            error "Failed to download bat Catppuccin Mocha theme"
        fi
    fi
fi

# ------------------------------------------------------------------
# Group: gh CLI extensions
# ------------------------------------------------------------------
if command -v gh &>/dev/null; then
    if confirm "Install gh CLI extensions (gh-dash, gh-enhance)?"; then
        if gh extension list 2>/dev/null | grep -q "dlvhdr/gh-dash"; then
            info "  gh-dash — already installed, skipping"
        else
            info "  Installing gh-dash..."
            if ! gh extension install dlvhdr/gh-dash; then
                error "Failed to install gh-dash"
            fi
        fi

        if gh extension list 2>/dev/null | grep -q "dlvhdr/gh-enhance"; then
            info "  gh-enhance — already installed, skipping"
        else
            info "  Installing gh-enhance..."
            if ! gh extension install dlvhdr/gh-enhance; then
                error "Failed to install gh-enhance"
            fi
        fi
    else
        info "Skipping gh CLI extensions."
    fi
else
    warn "gh CLI is not installed — skipping gh extensions"
fi

# ------------------------------------------------------------------
# Group 2: Fonts
# ------------------------------------------------------------------
# Pre-scan: check if fonts are already installed
FONTS_PENDING=0
if ! brew list --cask font-hack-nerd-font &>/dev/null && ! ls ~/Library/Fonts/HackNerdFont*.ttf &>/dev/null 2>&1; then
    FONTS_PENDING=$((FONTS_PENDING + 1))
fi
if ! brew list --cask font-jetbrains-mono-nerd-font &>/dev/null && ! ls ~/Library/Fonts/JetBrainsMonoNerdFont*.ttf &>/dev/null 2>&1; then
    FONTS_PENDING=$((FONTS_PENDING + 1))
fi

if [ "$FONTS_PENDING" -eq 0 ]; then
    info "Fonts: 2/2 installed"
elif confirm "Install terminal fonts ($FONTS_PENDING/2 pending)?"; then
    info "Installing terminal fonts..."
    if brew list --cask font-hack-nerd-font &>/dev/null; then
        info "  font-hack-nerd-font — already installed (via brew), skipping"
    elif ls ~/Library/Fonts/HackNerdFont*.ttf &>/dev/null 2>&1; then
        info "  font-hack-nerd-font — already installed (manual), skipping"
    else
        if ! brew install --cask font-hack-nerd-font; then
            error "Failed to install font-hack-nerd-font"
        fi
    fi
    if brew list --cask font-jetbrains-mono-nerd-font &>/dev/null; then
        info "  font-jetbrains-mono-nerd-font — already installed (via brew), skipping"
    elif ls ~/Library/Fonts/JetBrainsMonoNerdFont*.ttf &>/dev/null 2>&1; then
        info "  font-jetbrains-mono-nerd-font — already installed (manual), skipping"
    else
        if ! brew install --cask font-jetbrains-mono-nerd-font; then
            error "Failed to install font-jetbrains-mono-nerd-font"
        fi
    fi
else
    info "Skipping font installation."
fi

# ------------------------------------------------------------------
# Group 3: Oh-my-zsh + plugins
# ------------------------------------------------------------------
# Pre-scan: check if oh-my-zsh and plugins are already installed
OMZ_PENDING=0
[ -d "$HOME/.oh-my-zsh" ] || OMZ_PENDING=$((OMZ_PENDING + 1))
YSU_DIR="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/you-should-use"
[ -d "$YSU_DIR" ] || OMZ_PENDING=$((OMZ_PENDING + 1))
for pkg in zsh-autosuggestions zsh-syntax-highlighting zsh-completions; do
    brew list "$pkg" &>/dev/null || OMZ_PENDING=$((OMZ_PENDING + 1))
done

if [ "$OMZ_PENDING" -eq 0 ]; then
    info "Oh-my-zsh + plugins: 5/5 installed"
elif confirm "Install oh-my-zsh and zsh plugins ($OMZ_PENDING/5 pending)?"; then
    # oh-my-zsh
    if [ -d "$HOME/.oh-my-zsh" ]; then
        info "  oh-my-zsh — already installed, skipping"
    else
        info "  Installing oh-my-zsh..."
        if ! sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)" "" --unattended; then
            error "Failed to install oh-my-zsh"
        fi
    fi

    # you-should-use plugin (git clone)
    if [ -d "$YSU_DIR" ]; then
        info "  you-should-use plugin — already installed, skipping"
    else
        info "  Cloning you-should-use plugin..."
        if ! git clone https://github.com/MichaelAquilina/zsh-you-should-use.git "$YSU_DIR"; then
            error "Failed to clone you-should-use plugin"
        fi
    fi

    # zsh-autosuggestions and zsh-syntax-highlighting via brew
    for pkg in zsh-autosuggestions zsh-syntax-highlighting zsh-completions; do
        if brew list "$pkg" &>/dev/null; then
            info "  $pkg — already installed, skipping"
        else
            info "  Installing $pkg..."
            if ! brew install "$pkg"; then
                error "Failed to install $pkg"
            fi
        fi
    done
else
    info "Skipping oh-my-zsh and zsh plugins."
fi

# ------------------------------------------------------------------
# Group 4: Brew casks (GUI apps) — unified structured list
# Format: "cask-name|AppName|Category|Description"
# ------------------------------------------------------------------
ALL_CASKS=(
