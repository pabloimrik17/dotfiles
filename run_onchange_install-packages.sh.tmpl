install_cask() {
    local cask="$1"
    local app_name="$2"
    if [ -d "/Applications/$app_name.app" ]; then
        info "  $cask — already installed, skipping"
    else
        info "  Installing $cask..."
        if ! brew install --cask "$cask"; then
            error "Failed to install cask $cask"
        fi
    fi
}

# Pre-scan: build list of pending (uninstalled) casks
PENDING_CASKS=()
for entry in "${ALL_CASKS[@]}"; do
    IFS='|' read -r cask app_name category description <<< "$entry"
    if [ ! -d "/Applications/$app_name.app" ]; then
        PENDING_CASKS+=("$entry")
    fi
done

TOTAL_CASKS=${#ALL_CASKS[@]}
PENDING_COUNT=${#PENDING_CASKS[@]}
INSTALLED_COUNT=$((TOTAL_CASKS - PENDING_COUNT))

if [ "$PENDING_COUNT" -eq 0 ]; then
    # 0 pending: silent skip
    info "GUI apps: $TOTAL_CASKS/$TOTAL_CASKS installed"
elif [ "$PENDING_COUNT" -le 3 ]; then
    # 1-3 pending: direct confirm per app
    info "GUI apps: $INSTALLED_COUNT/$TOTAL_CASKS installed, $PENDING_COUNT pending"
    for entry in "${PENDING_CASKS[@]}"; do
        IFS='|' read -r cask app_name category description <<< "$entry"
        if confirm "Install $cask ($description)?"; then
            install_cask "$cask" "$app_name"
        else
            info "  Skipping $cask."
        fi
    done
else
    # 4+ pending: fzf picker or fallback
    info "GUI apps: $INSTALLED_COUNT/$TOTAL_CASKS installed, $PENDING_COUNT pending"
    if command -v fzf &>/dev/null; then
        # Build fzf input lines
        FZF_INPUT=""
        for entry in "${PENDING_CASKS[@]}"; do
            IFS='|' read -r cask app_name category description <<< "$entry"
            FZF_INPUT+="$(printf "[%-12s] %-30s %s" "$category" "$cask" "$description")"$'\n'
        done

        SELECTED="$(echo "$FZF_INPUT" | fzf --multi --no-sort \
            --header "TAB = toggle, Ctrl-A = select all, ENTER = confirm" \
            --bind "ctrl-a:toggle-all" \
            --bind 'enter:transform:(( FZF_SELECT_COUNT )) && echo accept || echo abort' \
            --prompt "Select GUI apps to install> " || true)"

        if [ -z "$SELECTED" ]; then
            info "  No apps selected, skipping."
        else
            while IFS= read -r line; do
                # Extract cask name from fzf line: [Category    ] cask-name ...
                selected_cask="$(echo "$line" | sed 's/^\[.*\] *//' | awk '{print $1}')"
                # Find the full entry to get app_name
                for entry in "${PENDING_CASKS[@]}"; do
                    IFS='|' read -r cask app_name category description <<< "$entry"
                    if [ "$cask" = "$selected_cask" ]; then
                        install_cask "$cask" "$app_name"
                        break
                    fi
                done
            done <<< "$SELECTED"
        fi
    else
        # Fallback: list all pending + single confirm
        info ""
        info "  Pending GUI apps:"
        for entry in "${PENDING_CASKS[@]}"; do
            IFS='|' read -r cask app_name category description <<< "$entry"
            info "    [$category] $cask — $description"
        done
        if confirm "Install all $PENDING_COUNT pending GUI apps?"; then
            for entry in "${PENDING_CASKS[@]}"; do
                IFS='|' read -r cask app_name category description <<< "$entry"
                install_cask "$cask" "$app_name"
            done
        else
            info "  Skipping GUI apps."
        fi
    fi
fi

# ------------------------------------------------------------------
# Group 5: Mac App Store apps (via mas)
# Format: "app_id|app_name|description"
# ------------------------------------------------------------------
MAS_APPS=(
    "6714467650|Perplexity|AI search assistant"
    "1568924476|Mela|Recipe manager"
)

if command -v mas &>/dev/null; then
    MAS_INSTALLED="$(mas list 2>/dev/null || true)"

    PENDING_MAS=()
    for entry in "${MAS_APPS[@]}"; do
        IFS='|' read -r app_id app_name description <<< "$entry"
        if ! echo "$MAS_INSTALLED" | grep -q "^$app_id "; then
            PENDING_MAS+=("$entry")
        fi
    done

    TOTAL_MAS=${#MAS_APPS[@]}
    PENDING_MAS_COUNT=${#PENDING_MAS[@]}

    if [ "$PENDING_MAS_COUNT" -eq 0 ]; then
        info "App Store apps: $TOTAL_MAS/$TOTAL_MAS installed"
    elif [ "$PENDING_MAS_COUNT" -le 3 ]; then
        info "App Store apps: $((TOTAL_MAS - PENDING_MAS_COUNT))/$TOTAL_MAS installed, $PENDING_MAS_COUNT pending"
        for entry in "${PENDING_MAS[@]}"; do
            IFS='|' read -r app_id app_name description <<< "$entry"
            if confirm "Install $app_name ($description)?"; then
                info "  Installing $app_name ($app_id)..."
                if ! mas install "$app_id"; then
                    error "Failed to install $app_name from App Store (are you signed in?)"
                fi
            else
                info "  Skipping $app_name."
            fi
        done
    else
        # 4+ pending: fzf picker or fallback (same pattern as casks)
        info "App Store apps: $((TOTAL_MAS - PENDING_MAS_COUNT))/$TOTAL_MAS installed, $PENDING_MAS_COUNT pending"
        if command -v fzf &>/dev/null; then
            FZF_MAS_INPUT=""
            for entry in "${PENDING_MAS[@]}"; do
                IFS='|' read -r app_id app_name description <<< "$entry"
                FZF_MAS_INPUT+="$(printf "%s|%-20s %s" "$app_id" "$app_name" "$description")"$'\n'
            done

            SELECTED_MAS="$(echo "$FZF_MAS_INPUT" | fzf --multi --no-sort \
                --header "TAB = toggle, Ctrl-A = select all, ENTER = confirm" \
                --bind "ctrl-a:toggle-all" \
                --bind 'enter:transform:(( FZF_SELECT_COUNT )) && echo accept || echo abort' \
                --with-nth=2.. --delimiter='|' \
                --prompt "Select App Store apps to install> " || true)"

            if [ -z "$SELECTED_MAS" ]; then
                info "  No apps selected, skipping."
            else
                while IFS= read -r line; do
                    selected_id="${line%%|*}"
                    for entry in "${PENDING_MAS[@]}"; do
                        IFS='|' read -r app_id app_name description <<< "$entry"
                        if [ "$app_id" = "$selected_id" ]; then
                            info "  Installing $app_name ($app_id)..."
                            if ! mas install "$app_id"; then
                                error "Failed to install $app_name from App Store (are you signed in?)"
                            fi
                            break
                        fi
                    done
                done <<< "$SELECTED_MAS"
            fi
        else
            info ""
            info "  Pending App Store apps:"
            for entry in "${PENDING_MAS[@]}"; do
                IFS='|' read -r app_id app_name description <<< "$entry"
                info "    $app_name — $description"
            done
            if confirm "Install all $PENDING_MAS_COUNT pending App Store apps?"; then
                for entry in "${PENDING_MAS[@]}"; do
                    IFS='|' read -r app_id app_name description <<< "$entry"
                    info "  Installing $app_name ($app_id)..."
                    if ! mas install "$app_id"; then
                        error "Failed to install $app_name from App Store (are you signed in?)"
                    fi
                done
            else
                info "  Skipping App Store apps."
            fi
        fi
    fi
else
    warn "mas is not installed — skipping App Store apps"
fi

# ------------------------------------------------------------------
# Group 6: NVM + Node LTS + Corepack
# ------------------------------------------------------------------
# Pre-scan: check if NVM, Node, and corepack are all present
NVM_DIR="${NVM_DIR:-$HOME/.nvm}"
# Source nvm so node/corepack are visible for the pre-scan
# shellcheck disable=SC1091
[ -s "$NVM_DIR/nvm.sh" ] && export NVM_DIR && . "$NVM_DIR/nvm.sh"
NVM_PENDING=0
[ -d "$NVM_DIR" ] || NVM_PENDING=$((NVM_PENDING + 1))
command -v node &>/dev/null || NVM_PENDING=$((NVM_PENDING + 1))
command -v corepack &>/dev/null || NVM_PENDING=$((NVM_PENDING + 1))

if [ "$NVM_PENDING" -eq 0 ]; then
    info "NVM/Node/corepack: 3/3 installed"
elif confirm "Install NVM, Node LTS, and enable corepack ($NVM_PENDING/3 pending)?"; then
    NVM_OK=false

    if [ -d "$NVM_DIR" ]; then
        info "  NVM — already installed ($NVM_DIR), skipping install"
        NVM_OK=true
    else
        info "  Installing NVM via official curl script..."
        # Pinned to known-good version for stability. Update periodically.
        if PROFILE=/dev/null bash -c 'curl -fsSL https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.4/install.sh | bash'; then
            NVM_OK=true
        else
            error "Failed to install NVM — skipping Node and corepack"
        fi
    fi

    if $NVM_OK; then
        # Source nvm so it's available in this session
        export NVM_DIR
        # shellcheck disable=SC1091
        [ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

        if command -v node &>/dev/null; then
            info "  Node — already installed ($(node --version)), skipping"
        else
            info "  Installing Node LTS..."
            if nvm install --lts; then
                nvm alias default 'lts/*'
            else
                error "Failed to install Node LTS"
            fi
        fi

        # Ensure default alias is set even if Node was already present
        if type nvm &>/dev/null; then
            nvm alias default 'lts/*' 2>/dev/null || true
        fi

        if command -v node &>/dev/null; then
            info "  Enabling corepack..."
            if ! corepack enable; then
                error "Failed to enable corepack"
            fi
        else
            warn "Node is not available — skipping corepack"
        fi
    fi
else
    info "Skipping NVM/Node/corepack."
fi

# ------------------------------------------------------------------
# Group 7: OpenCode plugins
# ------------------------------------------------------------------
if confirm "Install OpenCode plugin dependencies (plannotator, superpowers)?"; then
    if command -v opencode &>/dev/null; then
        if command -v plannotator &>/dev/null; then
            info "  plannotator — already installed, skipping"
        else
            info "  Installing plannotator..."
            if ! curl -fsSL https://plannotator.ai/install.sh | bash; then
                error "Failed to install plannotator"
            fi
            # plannotator installs to ~/.local/bin which may not be in PATH yet
            export PATH="$HOME/.local/bin:$PATH"
            if ! command -v plannotator &>/dev/null; then
                error "plannotator installed but not found in PATH"
            fi
        fi

        info "  Installing superpowers..."
        SUPERPOWERS_DIR="$HOME/.config/opencode/superpowers"
        if [ -d "$SUPERPOWERS_DIR" ]; then
            info "  superpowers — already installed, skipping"
        else
            if git clone https://github.com/obra/superpowers.git "$SUPERPOWERS_DIR"; then
                mkdir -p "$HOME/.config/opencode/plugins"
                ln -sf "$SUPERPOWERS_DIR/.opencode/plugins/superpowers.js" "$HOME/.config/opencode/plugins/superpowers.js"
                mkdir -p "$HOME/.config/opencode/skills"
                ln -sf "$SUPERPOWERS_DIR/skills" "$HOME/.config/opencode/skills/superpowers"
            else
                error "Failed to clone superpowers"
            fi
        fi
    else
        warn "OpenCode is not installed — skipping plugin setup"
    fi
else
    info "Skipping OpenCode plugin dependencies."
fi

