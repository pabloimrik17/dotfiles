# If you come from bash you might have to change your $PATH.
# export PATH=$HOME/bin:/usr/local/bin:$PATH

# XDG base dir — make tools resolve config under ~/.config consistently.
# Without this, macOS tools (glow → ~/Library/Preferences, lazygit → ~/Library/
# Application Support, …) bypass the chezmoi-managed ~/.config/* files. Must be
# set before any tool init below reads its config.
export XDG_CONFIG_HOME="$HOME/.config"

# Path to your oh-my-zsh installation.
export ZSH="{{ .chezmoi.homeDir }}/.oh-my-zsh"

# Set name of the theme to load --- if set to "random", it will
# load a random theme each time oh-my-zsh is loaded, in which case,
# to know which specific one was loaded, run: echo $RANDOM_THEME
# See https://github.com/robbyrussell/oh-my-zsh/wiki/Themes
# ZSH_THEME="spaceship"  # Commented out — using Starship instead

# Which plugins would you like to load?
# Standard plugins can be found in ~/.oh-my-zsh/plugins/*
# Custom plugins may be added to ~/.oh-my-zsh/custom/plugins/
plugins=(
  # Version control
  git
  gitignore

  # Tool completions & aliases
  brew
  docker
  docker-compose
  npm
  macos
  gh

  # Productivity utilities
  aliases
  colored-man-pages
  command-not-found
  copybuffer
  copyfile
  copypath
  encode64
  extract
  fancy-ctrl-z
  history
  jsontools
  safe-paste
  sudo
  bgnotify
  urltools
  web-search
  you-should-use

  # Runtime managers
  nvm
  bun
)

# Skip compaudit check — Homebrew directories are group-writable by design
ZSH_DISABLE_COMPFIX=true

# nvm plugin configuration (must be before oh-my-zsh source)
export NVM_DIR="$HOME/.nvm"
zstyle ':omz:plugins:nvm' lazy yes
zstyle ':omz:plugins:nvm' autoload yes
zstyle ':omz:plugins:nvm' silent-autoload yes

# zsh-completions — additional completion definitions (loaded before compinit)
{{- if eq .chezmoi.os "darwin" }}
{{-   if eq .chezmoi.arch "arm64" }}
[ -d /opt/homebrew/share/zsh-completions ] && fpath+=/opt/homebrew/share/zsh-completions
{{-   else }}
[ -d /usr/local/share/zsh-completions ] && fpath+=/usr/local/share/zsh-completions
{{-   end }}
{{- else }}
[ -d /usr/share/zsh-completions ] && fpath+=/usr/share/zsh-completions
{{- end }}

# Catppuccin Mocha theme for zsh-syntax-highlighting (must load before plugin)
[[ -f ~/.zsh/catppuccin_mocha-zsh-syntax-highlighting.zsh ]] && source ~/.zsh/catppuccin_mocha-zsh-syntax-highlighting.zsh

source $ZSH/oh-my-zsh.sh

# Pre-seed PATH with default nvm node for non-shell subprocesses (Gradle, Xcode)
if [ -d "$NVM_DIR/versions/node" ]; then
  _nvm_default_node_dir=$(command ls -1d "$NVM_DIR/versions/node/"v* 2>/dev/null | sort -V | tail -1)
  [ -n "$_nvm_default_node_dir" ] && export PATH="$_nvm_default_node_dir/bin:$PATH"
  unset _nvm_default_node_dir
fi

# User configuration
export EDITOR="code --wait"
export VISUAL="code --wait"
export OPENCODE_EXPERIMENTAL_LSP_TOOL=true
export OPENCODE_ENABLE_EXA=true
export OPENCODE_EXPERIMENTAL_OXFMT=true
export OPENCODE_EXPERIMENTAL_FILEWATCHER=true

test -e "${HOME}/.iterm2_shell_integration.zsh" && source "${HOME}/.iterm2_shell_integration.zsh"

# pnpm
export PNPM_HOME="{{ .chezmoi.homeDir }}/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

# ====================================================================
# MODERN CLI TOOLS CONFIGURATION
# ====================================================================

# bat/delta theme - Catppuccin Mocha (case-sensitive)
export BAT_THEME="Catppuccin Mocha"

# Starship prompt - Fast, customizable prompt for any shell
eval "$(starship init zsh)"

# fzf - Fuzzy finder for command history and files
{{- if eq .chezmoi.os "darwin" }}
{{-   if eq .chezmoi.arch "arm64" }}
if [[ ! "$PATH" == */opt/homebrew/opt/fzf/bin* ]]; then
  PATH="${PATH:+${PATH}:}/opt/homebrew/opt/fzf/bin"
fi
{{-   else }}
if [[ ! "$PATH" == */usr/local/opt/fzf/bin* ]]; then
  PATH="${PATH:+${PATH}:}/usr/local/opt/fzf/bin"
fi
{{-   end }}
{{- end }}
{{/* Linux: fzf installed via package manager, already in PATH */}}
source <(fzf --zsh)

# fd as fzf backend - much faster than default find
export FZF_DEFAULT_COMMAND='fd --type f --strip-cwd-prefix --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND='fd --type d --strip-cwd-prefix --hidden --follow --exclude .git'

# fzf enhanced configuration
export FZF_DEFAULT_OPTS="
  --height 40%
  --layout=reverse
  --border
  --preview 'case {} in *.md|*.markdown) glow -s auto -- {};; *) bat --color=always --style=numbers --line-range=:500 -- {};; esac'
  --preview-window=right:60%
  --bind='ctrl-/:toggle-preview'
  --color=bg+:#313244,bg:#1E1E2E,spinner:#F5E0DC,hl:#F38BA8
  --color=fg:#CDD6F4,header:#F38BA8,info:#CBA6F7,pointer:#F5E0DC
  --color=marker:#B4BEFE,fg+:#CDD6F4,prompt:#CBA6F7,hl+:#F38BA8
  --color=selected-bg:#45475A,border:#6C7086,label:#CDD6F4
"
export FZF_CTRL_T_OPTS="--preview 'case {} in *.md|*.markdown) glow -s auto -- {};; *) bat --color=always --style=numbers --line-range=:500 -- {};; esac'"
export FZF_ALT_C_OPTS="--preview 'eza --tree --color=always {} | head -200'"

# television - Smart fuzzy finder with context-aware autocomplete
# Init order: fzf → tv → atuin. tv overrides fzf's Ctrl+T with smart
# autocomplete; atuin then overrides tv's Ctrl+R for AI-powered history.
if command -v tv &>/dev/null; then
  eval "$(tv init zsh)"
  # Wrap Ctrl+T: empty prompt → fzf file picker, non-empty → tv smart autocomplete.
  # tv's default empty-prompt fallback uses fzf_default_completion which is also used
  # by fzf's Tab handler — overriding it globally breaks normal Tab completion.
  _tv_ctrl_t_wrapper() {
    if [[ ${#${(z)LBUFFER}} -lt 1 ]]; then
      fzf-file-widget
    else
      _tv_smart_autocomplete
    fi
  }
  zle -N tv-smart-autocomplete _tv_ctrl_t_wrapper
fi

# atuin - Modern shell history (replaces fzf's Ctrl+R)
eval "$(atuin init zsh --disable-up-arrow)"
eval "$(atuin ai init zsh)"

# Worktrunk - Git worktree management (cd integration + completions)
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init zsh)"; fi

# Zsh plugins
{{- if eq .chezmoi.os "darwin" }}
{{-   if eq .chezmoi.arch "arm64" }}
[ -f /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{-   else }}
[ -f /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && source /usr/local/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && source /usr/local/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{-   end }}
{{- else }}
[ -f /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh ] && source /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[ -f /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ] && source /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
{{- end }}

# Autosuggestions tuning (catppuccin-mocha palette)
# Alternative: ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#9399b2"          # Overlay 2 — subtle grey, no background
# Alternative: ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#4d7d96"          # Sapphire dimmed 50% — oceanic tone, no background
ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#cba6f7,bg=#585b70"
ZSH_AUTOSUGGEST_BUFFER_MAX_SIZE=20
ZSH_AUTOSUGGEST_USE_ASYNC=true

# ====================================================================
# ALIASES - Modern replacements for classic commands
# ====================================================================

# eza (modern ls replacement)
alias ls="eza --icons --group-directories-first"
alias ll="eza --icons --group-directories-first -l"
alias la="eza --icons --group-directories-first -la"
alias lt="eza --icons --group-directories-first --tree --level=2"
alias lta="eza --icons --group-directories-first --tree --level=2 -a"

# bat (modern cat replacement)
alias cat="bat --style=auto"
alias catp="bat --style=plain"  # No line numbers or decorations

# Markdown viewing — glow (default renderer) + mdfried (graphics-rich companion).
# `mdview` is the single dispatcher every surface (md, television, lazygit) calls,
# so the glow-vs-mdfried policy lives in one place. `cat`→`bat` (source highlight)
# is a different job and stays untouched.
__md_has_visuals() {
  # True when the doc has an embedded image or a mermaid fence (where mdfried adds value).
  grep -qE '!\[.*\]\(.*\)' "$1" 2>/dev/null && return 0
  grep -qE '^[[:space:]]*```mermaid' "$1" 2>/dev/null
}
__md_graphics_capable() {
  if [ -n "${TMUX:-}" ]; then
    # Inside tmux, graphics escapes only pass through with passthrough on, AND
    # tmux masks the outer terminal's $TERM/$TERM_PROGRAM — so passthrough alone
    # is not proof of graphics support. Require a marker that survives into the
    # pane (Ghostty/Kitty export these); otherwise assume no graphics → glow.
    [ "$(tmux show -gv allow-passthrough 2>/dev/null)" = "on" ] || return 1
    [ -n "${KITTY_WINDOW_ID:-}" ] && return 0
    [ -n "${GHOSTTY_RESOURCES_DIR:-}" ] && return 0
    return 1
  fi
  # Outside tmux: terminals that speak a graphics protocol (Kitty / iTerm2 / Sixel).
  if [ -n "${KITTY_WINDOW_ID:-}" ] || [ -n "${GHOSTTY_RESOURCES_DIR:-}" ]; then return 0; fi
  case "${TERM_PROGRAM:-}" in ghostty|iTerm.app|WezTerm) return 0 ;; esac
  [ "${LC_TERMINAL:-}" = "iTerm2" ] && return 0
  case "${TERM:-}" in xterm-kitty|xterm-ghostty|*-sixel) return 0 ;; esac
  return 1
}
mdview() {
  # Non-TTY (piped): render to stdout with glow, never a full-screen TUI.
  [ -t 1 ] || { glow "$@"; return; }
  # Explicit override wins, unconditionally.
  case "${MD_VIEWER:-auto}" in
    glow)    glow -p "$@"; return ;;
    mdfried) mdfried "$@"; return ;;
  esac
  # Auto: mdfried only for graphics-rich docs in a graphics-capable terminal; else glow's pager.
  if [ -f "${1:-}" ] && __md_has_visuals "$1" && __md_graphics_capable; then
    mdfried "$@"
  else
    glow -p "$@"
  fi
}
# oh-my-zsh's lib/directories.zsh (sourced above) aliases `md='mkdir -p'`. zsh
# refuses to define a function whose name is an active alias and aborts the rest
# of this file — drop the alias first so `md()` parses.
unalias md 2>/dev/null
md() {
  # No args → glow's directory-browsing TUI; with args → the mdview dispatcher.
  if [ "$#" -eq 0 ]; then glow; else mdview "$@"; fi
}

